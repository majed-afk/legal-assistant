# ============================================================
# Sanad AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Claude API (Required) ---
ANTHROPIC_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Security ---
API_KEY=your_api_key_here
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_DAY=100

# --- Supabase (Required for subscriptions, feedback, analytics) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# --- Moyasar Payment Gateway ---
MOYASAR_SECRET_KEY=your_moyasar_secret_key
MOYASAR_PUBLISHABLE_KEY=your_moyasar_publishable_key
MOYASAR_CALLBACK_URL=https://your-domain.com/subscription/callback
MOYASAR_WEBHOOK_SECRET=your_moyasar_webhook_secret

# --- PayPal Payment Gateway ---
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET_KEY=your_paypal_secret_key
PAYPAL_MODE=sandbox

# --- Monitoring (Optional) ---
SENTRY_DSN=
ENVIRONMENT=development

# --- Deployment ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
